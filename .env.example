# OPCIONAL: o Studio Native salva as chaves pela tela "Ajustes" em
# %APPDATA%/StudioNative/config.json. Este .env serve apenas como fallback
# para desenvolvimento (precedencia: config.json > .env > default).

# Chave da OpenRouter (geracao de frases/roteiros)
OPENROUTER_API_KEY=

# Modelo usado para gerar as frases/roteiros (qualquer modelo da OpenRouter)
OPENROUTER_MODEL=openai/gpt-4o-mini

# (Opcional) Modo com narracao por voz via ElevenLabs.
# Pegue sua chave em https://elevenlabs.io (Profile > API Keys)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

# (Opcional) Porta do backend em dev. O Electron define STUDIO_PORT automaticamente.
PORT=5050
